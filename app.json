{
  "expo": {
    "name": "Synq",
    "slug": "synq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "synq",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A6B58"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stefaniebaarman.synq",
      "buildNumber": "4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#1A6B58"
      },
      "package": "com.stefaniebaarman.synq",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Synq uses your location for nearby hangout suggestions and place search when you use those features."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Synq needs access to your photo library so you can choose a profile photo.",
          "cameraPermission": "Synq can use the camera when you take a new profile photo."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "15.1"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.stefaniebaarman.synq.widgets",
          "groupIdentifier": "group.com.stefaniebaarman.synq",
          "widgets": [
            {
              "name": "SynqGlanceWidget",
              "displayName": "Synq",
              "description": "Your Synq status and memo at a glance.",
              "supportedFamilies": ["systemSmall", "systemMedium"]
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "27049d71-1c6b-4aa5-b874-1a6ddcb2b5be"
      }
    },
    "owner": "stefaniebaarman"
  }
}
